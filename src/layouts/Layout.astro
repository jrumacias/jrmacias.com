---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'jrmacias',
  description = 'jrmacias.com',
  image,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://jrmacias.com');
const ogImage = image
  ? new URL(image, Astro.site ?? 'https://jrmacias.com').toString()
  : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="jrmacias blog" href="/rss.xml" />
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="jrmacias" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <!-- Twitter/X card -->
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <title>{title}</title>
    <!-- Runs before paint to prevent flash of wrong theme -->
    <script is:inline>
      if (localStorage.getItem('theme') === 'light') {
        document.documentElement.classList.add('light');
      }
    </script>
  </head>
  <body>
    <nav class="site-nav">
      <div class="site-nav-inner">
        <a href="/" class="nav-link">HOME</a>
        <a href="/blog" class="nav-link">BLOG</a>
      </div>
    </nav>
    <ThemeToggle />
    <slot />
  </body>

<style>
  .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10;
    padding: 1.25rem 1.5rem;
    background: var(--bg-translucent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .site-nav-inner {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .nav-link {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: var(--muted);
    text-decoration: none;
    border: 1px solid var(--border);
    padding: 0.3rem 0.65rem;
    transition: color 0.15s, border-color 0.15s, box-shadow 0.15s;
  }
  .nav-link:hover {
    color: var(--text);
    border-color: var(--muted);
    box-shadow: 0 0 6px var(--border);
  }
</style>

<script>
  // ── Animated dot-grid background ─────────────────────────────
  const SPACING      = 28;
  const DOT_R        = 1;
  const WAVE_INTERVAL  = 9000; // ms between wave starts
  const WAVE_DURATION  = 2400; // ms for wave to cross the full diagonal
  const WAVE_WIDTH     = 320;  // px spread of the wave band

  const canvas = document.createElement('canvas');
  canvas.style.cssText = 'position:fixed;inset:0;width:100%;height:100%;z-index:-1;pointer-events:none;';
  document.body.prepend(canvas);
  const ctx = canvas.getContext('2d')!;

  function resize() {
    canvas.width  = window.innerWidth;
    canvas.height = window.innerHeight;
  }
  window.addEventListener('resize', resize);
  resize();

  // Trigger first wave immediately
  let lastWaveTime = -WAVE_INTERVAL;

  function frame(ts: number) {
    const w = canvas.width;
    const h = canvas.height;
    const isLight   = document.documentElement.classList.contains('light');
    const baseAlpha = isLight ? 0.10 : 0.07;
    const peakAlpha = isLight ? 0.20 : 0.18;
    const rgb       = isLight ? '0,0,0' : '255,255,255';

    ctx.clearRect(0, 0, w, h);

    if (ts - lastWaveTime >= WAVE_INTERVAL) lastWaveTime = ts;
    const elapsed   = ts - lastWaveTime;
    const maxDiag   = w + h;
    const waveFront = (elapsed / WAVE_DURATION) * (maxDiag + WAVE_WIDTH);

    for (let x = 0; x <= w + SPACING; x += SPACING) {
      for (let y = 0; y <= h + SPACING; y += SPACING) {
        // Each dot's distance from the bottom-left corner
        const d             = x + (h - y);
        const distFromFront = waveFront - d;
        let alpha = baseAlpha;
        if (distFromFront >= 0 && distFromFront <= WAVE_WIDTH) {
          const t = distFromFront / WAVE_WIDTH;
          alpha = baseAlpha + (peakAlpha - baseAlpha) * Math.sin(t * Math.PI);
        }
        ctx.beginPath();
        ctx.arc(x, y, DOT_R, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${rgb},${alpha})`;
        ctx.fill();
      }
    }

    requestAnimationFrame(frame);
  }

  requestAnimationFrame(frame);
</script>
</html>
