---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft && !data.private);
  const tags = [...new Set(posts.flatMap(p => p.data.tags))];
  return tags.map(tag => ({
    params: { tag },
    props: {
      posts: posts
        .filter(p => p.data.tags.includes(tag))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { tag } = Astro.params;
const { posts } = Astro.props;

function readingTime(body: string | undefined): string {
  if (!body) return '1 min read';
  const words = body.trim().split(/\s+/).length;
  const mins = Math.max(1, Math.round(words / 200));
  return `${mins} min read`;
}
---

<Layout title={`#${tag} / jrmacias`} description={`Posts tagged #${tag}`}>
  <main>
    <div class="header">
      <a href="/blog" class="back">← blog</a>
      <h1>#{tag}</h1>
      <p class="subtitle">{posts.length} post{posts.length !== 1 ? 's' : ''}</p>
    </div>

    <ul class="post-list">
      {posts.map(post => (
        <li>
          <a href={`/blog/${post.slug}`} class="post-link">
            <span class="post-date">{post.data.date.toISOString().slice(0, 10)}</span>
            <span class="post-title">{post.data.title}</span>
            <span class="post-meta">
              {readingTime(post.body)}
              {post.data.tags.filter(t => t !== tag).map(t => (
                <span class="post-tag">#{t}</span>
              ))}
            </span>
          </a>
        </li>
      ))}
    </ul>
  </main>
</Layout>

<style>
  main {
    max-width: 720px;
    margin: 0 auto;
    padding: 4rem 1.5rem 6rem;
  }

  .header { margin-bottom: 3rem; }

  .back {
    display: inline-block;
    font-size: 0.75rem;
    color: var(--muted);
    text-decoration: none;
    letter-spacing: 0.06em;
    margin-bottom: 1.5rem;
    transition: color 0.15s;
  }
  .back:hover { color: var(--text); }

  h1 {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 700;
    color: var(--text);
    margin: 0 0 0.5rem;
  }

  .subtitle {
    font-size: 0.8rem;
    color: var(--muted);
    letter-spacing: 0.04em;
    margin: 0;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-link {
    display: grid;
    grid-template-columns: 7rem 1fr;
    grid-template-rows: auto auto;
    column-gap: 1.5rem;
    row-gap: 0.25rem;
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: var(--text);
    transition: opacity 0.15s;
  }
  .post-link:hover { opacity: 0.7; }

  .post-date {
    font-size: 0.7rem;
    color: var(--muted);
    letter-spacing: 0.04em;
    padding-top: 0.15rem;
    grid-row: 1;
  }

  .post-title {
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    grid-row: 1;
  }

  .post-meta {
    font-size: 0.7rem;
    color: var(--muted);
    letter-spacing: 0.04em;
    grid-column: 2;
    grid-row: 2;
    display: flex;
    gap: 0.75rem;
  }

  .post-tag { color: var(--muted); }
</style>
