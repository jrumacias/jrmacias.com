---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main>
    <section class="hero">
      <p class="greeting">hello, i'm juan.</p>
      <button id="contact-btn" class="contact-btn">
        send a message <span class="arrow">→</span>
      </button>
    </section>

    <section id="contact-section" class="contact-section" aria-hidden="true">
      <form id="contact-form" action="https://formspree.io/f/mbdzlklq" method="POST" novalidate>
        <div class="field">
          <label for="email">your email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="you@example.com"
            autocomplete="email"
          />
        </div>
        <div class="field">
          <label for="message">message</label>
          <textarea
            id="message"
            name="message"
            required
            rows="4"
            placeholder="say hi..."
          ></textarea>
        </div>
        <div class="form-footer">
          <button type="submit" id="submit-btn" class="submit-btn">send →</button>
          <button type="button" id="cancel-btn" class="cancel-btn">cancel</button>
        </div>
      </form>

      <p id="success-msg" class="success-msg" hidden aria-live="polite">
        message sent. talk soon.
      </p>
    </section>
  </main>
</Layout>

<style>
  main {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    gap: 2.5rem;
  }

  /* ── Hero ─────────────────────────────────────────────────── */
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    text-align: center;
  }

  .greeting {
    font-size: clamp(1.75rem, 5vw, 3rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    background: linear-gradient(
      90deg,
      var(--shine-dim) 0%,
      var(--shine-bright) 50%,
      var(--shine-dim) 100%
    );
    background-size: 250% auto;
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: shine 6s linear infinite;
  }

  @keyframes shine {
    0%   { background-position: 200% center; }
    100% { background-position: -200% center; }
  }

  .contact-btn {
    background: none;
    border: none;
    color: var(--muted);
    font-family: inherit;
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    cursor: pointer;
    padding: 0;
    transition: color 0.15s ease;
  }

  .contact-btn:hover {
    color: var(--text);
  }

  .contact-btn:hover .arrow {
    transform: translateX(3px);
    display: inline-block;
    transition: transform 0.15s ease;
  }

  /* ── Contact form ─────────────────────────────────────────── */
  .contact-section {
    width: 100%;
    max-width: 28rem;
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.35s ease;
    overflow: hidden;
  }

  .contact-section.open {
    grid-template-rows: 1fr;
  }

  form,
  .success-msg {
    overflow: hidden;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1.25rem;
  }

  label {
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: var(--muted);
    text-transform: lowercase;
  }

  input,
  textarea {
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: inherit;
    font-size: 0.8rem;
    padding: 0.6rem 0.75rem;
    width: 100%;
    outline: none;
    border-radius: 0;
    transition: border-color 0.15s ease;
    resize: vertical;
  }

  input::placeholder,
  textarea::placeholder {
    color: var(--muted);
  }

  input:focus,
  textarea:focus {
    border-color: var(--text);
  }

  .form-footer {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-top: 0.25rem;
  }

  .submit-btn {
    background: none;
    border: none;
    color: var(--text);
    font-family: inherit;
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    cursor: pointer;
    padding: 0;
    transition: opacity 0.15s ease;
  }

  .submit-btn:hover {
    opacity: 0.7;
  }

  .submit-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .cancel-btn {
    background: none;
    border: none;
    color: var(--muted);
    font-family: inherit;
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    cursor: pointer;
    padding: 0;
    transition: color 0.15s ease;
  }

  .cancel-btn:hover {
    color: var(--text);
  }

  .success-msg {
    font-size: 0.85rem;
    color: var(--muted);
    text-align: center;
  }
</style>

<script>
  const contactBtn    = document.getElementById('contact-btn')!;
  const cancelBtn     = document.getElementById('cancel-btn')!;
  const contactSection = document.getElementById('contact-section')!;
  const form          = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn     = document.getElementById('submit-btn') as HTMLButtonElement;
  const successMsg    = document.getElementById('success-msg')!;

  function openForm() {
    contactBtn.style.display = 'none';
    contactSection.classList.add('open');
    contactSection.removeAttribute('aria-hidden');
    form.querySelector('input')?.focus();
  }

  function closeForm() {
    contactSection.classList.remove('open');
    contactSection.setAttribute('aria-hidden', 'true');
    setTimeout(() => {
      contactBtn.style.display = '';
    }, 350); // match transition duration
  }

  contactBtn.addEventListener('click', openForm);
  cancelBtn.addEventListener('click', closeForm);

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'sending...';

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (response.ok) {
        form.hidden = true;
        successMsg.hidden = false;
      } else {
        submitBtn.disabled = false;
        submitBtn.textContent = 'send →';
        alert('something went wrong. please try again.');
      }
    } catch {
      submitBtn.disabled = false;
      submitBtn.textContent = 'send →';
      alert('something went wrong. please try again.');
    }
  });
</script>
